<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.mbridak.not1mm</id>
  
  <name>Not1MM</name>
  <summary>Ham radio contest logger</summary>
  
  <metadata_license>MIT</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  
  <description>
    <p>
      Not1MM attempts to be a usable amateur radio, or Ham, contest logger. It&apos;s written in Python, and uses the Qt6 framework for the graphical interface and SQLite for the database. It supports CW, SSB, RTTY and other operating modes.
    </p>
  </description>
  
